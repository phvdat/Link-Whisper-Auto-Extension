{
  "manifest_version": 3,
  "name": "Link Whisper Auto",
  "version": "1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*/wp-admin/*"],
  "content_scripts": [
    {
      "matches": ["*://*/wp-admin/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
